* {
  box-sizing: border-box;
}

/* =========================
   BODY + PAGE TRANSITIONS
========================= */
body {
  margin: 0;
  opacity: 0;
  font-family: "Inter", sans-serif;
  background: #000;
  color: #f5f5dc;
  animation: fadeIn 0.3s ease forwards;
  transition: opacity 0.3s ease;
}

body.fade-out {
  opacity: 0;
}

/* =========================
   HERO
========================= */

a {
  color: inherit;
  text-decoration: none;
}
.hero-split {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  min-height: 100vh;
  align-items: center;
  padding: 40px;
}

.hero-left {
  padding-left: 100px;
  max-width: 420px;
}

.hero-left h1 {
  font-family: "Playfair Display", serif;
  font-size: 28px;
  letter-spacing: 2px;
}

.hero-left p {
  color: #bbb;
}

/* =========================
   HERO RIGHT (HOME ONLY)
========================= */
.hero-right {
  text-align: right;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.hero-right a {
  font-family: "Playfair Display", serif;
  display: inline-block;
  text-decoration: none;
  color: #e6e2d3;

  font-size: clamp(40px, 6vw, 60px);
  letter-spacing: 1px;
  line-height: 0.9;

  transition:
    transform 0.3s ease,
    opacity 0.3s ease,
    color 0.3s ease;
}

.hero-right a:hover {
  transform: translateX(20px);
  opacity: 1;
  color: #ffffff;
}

.hero-right:hover a {
  opacity: 0.3;
}

.hero-right a:hover {
  opacity: 1;
}

.hero-right h2:first-child a {
  opacity: 0.7;
  font-size: clamp(45px, 7vw, 90px);
}

/* RIGHT SIDE (ABOUT PAGE ONLY) */
.about-right {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40px;
}

/* HEADSHOT */
.about-img {
  width: 100%;
  max-width: 380px; /* controls size */
  height: auto;

  border-radius: 16px;
  object-fit: cover;

  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);

  transition: all 0.4s ease;
}

/* hover */
.about-img:hover {
  transform: scale(1.03);
  box-shadow: 0 25px 80px rgba(0, 0, 0, 0.8);
}

/* =========================
   SKILLS TABLE 
========================= */
.skills-table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 20px;
  font-size: 15px;
}

.skills-table th,
.skills-table td {
  padding: 14px 12px;
  text-align: left;
}

.skills-table th {
  color: #f5f5dc;
  font-weight: 500;
  border-bottom: 1px solid rgba(255, 255, 255, 0.2);
}

.skills-table td {
  color: #ccc;
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

/* hover row */
.skills-table tr:hover td {
  background: rgba(255, 255, 255, 0.05);
}

/* =========================
   SCROLL FADE-IN 
========================= */
.fade-in {
  opacity: 0;
  transform: translateY(40px);
  transition:
    opacity 0.6s ease,
    transform 0.6s ease;
}

.fade-in.show {
  opacity: 1;
  transform: translateY(0);
}

/* =========================
   NAV
========================= */
.top-nav {
  position: fixed;
  top: 25px;
  right: 40px;
  z-index: 1000;
  opacity: 0.7;
}

.top-nav ul {
  display: flex;
  gap: 18px;
  list-style: none;
}

.top-nav a {
  color: #aaa;
  text-decoration: none;
  font-size: 13px;
}

.top-nav a:hover,
.top-nav a.active {
  color: #fff;
}

/* =========================
   SIDE ICONS
========================= */
.side-icons {
  position: fixed;
  top: 40px;
  left: 30px;
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.side-icons img {
  width: 28px;
  transition: 0.3s;
}

.side-icons img:hover {
  transform: scale(1.2);
  filter: brightness(1.2);
}

.side-icons::after {
  content: "";
  width: 2px;
  height: 80px;
  background: #888;
}

/* =========================
   PROJECTS PAGE ONLY
========================= */
.projects-page .project-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
  padding: 60px 40px;
}

.projects-page .project-card {
  display: block;
  padding: 20px;
  border-radius: 14px;
  text-decoration: none;
  color: inherit;
  position: relative;

  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.08);

  transition: all 0.3s ease;

  /* animation ONLY on projects page */
  opacity: 0;
  transform: translateY(40px);
}

/* stagger */
.projects-page .project-grid.show .project-card {
  opacity: 1;
  transform: translateY(0);
  transition: all 0.6s ease;
}

.projects-page .project-grid.show .project-card:nth-child(1) {
  transition-delay: 0.1s;
}

.projects-page .project-grid.show .project-card:nth-child(2) {
  transition-delay: 0.25s;
}

.projects-page .project-grid.show .project-card:nth-child(3) {
  transition-delay: 0.4s;
}

/* image */
.projects-page .project-image {
  width: 100%;
  height: 200px; /* slightly taller for better fit */
  border-radius: 10px;
  overflow: hidden;
  margin-bottom: 15px;
  background: rgba(255, 255, 255, 0.05);
}

.projects-page .project-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  padding: 0;
  filter: grayscale(100%);
  transition: 0.3s ease;
}

/* text */
.projects-page .project-card h3 {
  margin-bottom: 8px;
}

.projects-page .project-card p {
  color: #bbb;
  font-size: 14px;
}

/* hover reveal */
.projects-page .project-link {
  margin-top: 15px;
  font-size: 14px;
  color: #e6e2d3;
  opacity: 0;
  transform: translateX(-10px);
  transition: 0.3s;
}

.projects-page .project-card:hover .project-link {
  opacity: 1;
  transform: translateX(0);
}

/* hover effects */
.projects-page .project-card:hover {
  transform: translateY(-8px) scale(1.01);
  border-color: rgba(255, 255, 255, 0.3);
  box-shadow:
    0 0 40px rgba(230, 226, 211, 0.15),
    0 20px 60px rgba(0, 0, 0, 0.6);
}

.projects-page .project-card:hover img {
  filter: grayscale(0%);
  transform: scale(1.05);
}

.projects-page .project-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(
    circle at top,
    rgba(255, 255, 255, 0.08),
    transparent 70%
  );
  opacity: 0;
  transition: 0.3s;
}

.projects-page .project-card:hover::before {
  opacity: 1;
}
/* =========================
   CONTENT SECTION
========================= */
.content-section {
  max-width: 800px;
  margin: 60px auto;
  padding: 40px;
}

/* =========================
   EXPERIENCE (MATCH EDUCATION)
========================= */

.experience-row {
  display: flex;
  gap: 25px;
  align-items: flex-start;
}

/* logo */
.experience-logo img {
  width: 60px;
  height: auto;
  object-fit: contain;
}

/* text */
.experience-text h3 {
  margin-bottom: 5px;
  font-size: 20px;
}

.experience-text .company {
  font-size: 14px;
  letter-spacing: 1px;
  color: #aaa;
  margin-bottom: 5px;
}

.experience-text .date {
  font-size: 13px;
  color: #777;
  margin-bottom: 10px;
}

.experience-text p {
  color: #bbb;
  line-height: 1.6;
}

.experience-text ul {
  padding-left: 20px;
  margin-top: 10px;
}

.experience-text li {
  margin-bottom: 6px;
  color: #ccc;
}

/* divider line */
.exp-divider {
  margin: 30px 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

/* =========================
   EDUCATION 
========================= */

.education-title {
  margin-bottom: 40px;
  font-size: 26px;
  letter-spacing: 2px;
}

/* layout */
.education-row {
  display: flex;
  gap: 25px;
  align-items: flex-start;
}

/* logo */
.education-logo img {
  width: 70px;
  height: auto;
  object-fit: contain;
}

/* text */
.education-text h3 {
  margin-bottom: 5px;
  font-size: 20px;
}

.education-text .school {
  font-size: 14px;
  letter-spacing: 1px;
  color: #aaa;
  margin-bottom: 5px;
}

.education-text .date {
  font-size: 13px;
  color: #777;
  margin-bottom: 12px;
}

/* coursework */
.education-text .coursework {
  color: #bbb;
  line-height: 1.6;
  margin-bottom: 12px;
}

/* tags */
.education-tags span {
  display: inline-block;
  padding: 5px 10px;
  margin-right: 10px;
  font-size: 12px;

  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 4px;
  color: #ccc;
}

/* =========================
   CONTACT FORM
========================= */
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 12px;
  max-width: 500px;
}

.contact-form label {
  font-size: 13px;
  color: #aaa;
}

.contact-form input,
.contact-form textarea {
  padding: 10px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 8px;
  background: transparent;
  color: #f5f5dc;
  font-family: inherit;
}

.contact-form textarea {
  min-height: 120px;
  resize: vertical;
}

/* button */
.contact-form button {
  margin-top: 10px;
  padding: 10px;
  border: none;
  border-radius: 8px;
  background: #e6e2d3;
  color: #000;
  cursor: pointer;
  transition: 0.3s;
}

.contact-form button:hover {
  background: #ffffff;
}

video {
  border-radius: 12px;
  margin-top: 20px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
}

/* =========================
   FOOTER
========================= */
.site-footer {
  position: fixed;
  left: 30px;
  bottom: 25px;
  font-size: 12px;
  color: #aaa;
}

/* =========================
   ANIMATIONS
========================= */
@keyframes fadeIn {
  to {
    opacity: 1;
  }
}

@keyframes cardFade {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* =========================
   MOBILE
========================= */
@media (max-width: 800px) {
  .project-grid {
    grid-template-columns: 1fr;
  }

  .hero-split {
    grid-template-columns: 1fr;
  }

  .hero-left {
    padding-left: 40px;
  }
}
